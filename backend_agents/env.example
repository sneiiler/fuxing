# =============================================================================
# Office Tools Backend Agent - Environment Configuration
# =============================================================================

# 应用基础配置
APP_NAME=office-agent-backend
ENV=dev
LOG_LEVEL=info
PORT=8000
CONTRACT_VERSION=v1.0.0

# =============================================================================
# 嵌入服务配置 (Embedding Service Configuration)
# =============================================================================

# OpenAI API 配置 - 必需
EMBEDDING_API_KEY=your_openai_api_key_here

# 可选：如果使用自定义API端点（如Azure OpenAI）
# EMBEDDING_BASE_URL=https://your-custom-endpoint.openai.azure.com/

# 嵌入模型配置
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# 批处理配置
EMBEDDING_BATCH_SIZE=10

# =============================================================================
# 重排序服务配置 (Rerank Service Configuration)
# =============================================================================

# 硅基流动 API 配置
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/

# =============================================================================
# 数据库配置 (Database Configuration)
# =============================================================================

# PostgreSQL 数据库连接 (可选)
# POSTGRES_DSN=postgresql://user:password@localhost:5432/dbname

# Redis 配置 (可选)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 对象存储配置 (Object Storage Configuration)
# =============================================================================

# S3 兼容存储配置 (可选)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# =============================================================================
# 使用说明
# =============================================================================

# 1. 复制此文件为 .env
# 2. 填入你的实际配置值
# 3. 确保 .env 文件不被提交到版本控制系统
# 4. 重启应用以使新配置生效

